# ==== OpenAI ====
OPENAI_API_KEY=

# ==== Pinecone (serverless) ====
PINECONE_API_KEY=
# Você pode apontar por NOME do index (criado via API/console) e/ou HOST
PINECONE_INDEX_NAME=my-multiuser-index
# Opcionalmente, use HOST direto quando já existir
PINECONE_INDEX_HOST=

# ==== PostgreSQL Database ====
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# ==== Segurança / Auth ====
JWT_SECRET=change-me-to-a-random-secret-in-production
# Sessões opacas em cookies HttpOnly + CSRF Protection
# TTL da sessão em minutos (padrão: 2 horas)
SESSION_TTL_MINUTES=120

# DESENVOLVIMENTO LOCAL: Se estiver usando HTTP (não HTTPS),
# edite backend/app/security.py e troque secure=True para secure=False
# PRODUÇÃO: SEMPRE use secure=True com HTTPS

# ==== Redis (Session Storage + Job Queue) ====
# Para desenvolvimento local: redis://localhost:6379/0
# Para produção com senha: redis://:password@host:6379/0
# Para Redis Cloud/TLS: rediss://username:password@host:port
REDIS_URL=redis://localhost:6379/0

# ==== Crawler ====
HEADLESS=true
BATCH_SIZE=12
CRAWL_DELAY_MS=0
USER_AGENT=pg-multi-crawler/1.0

# ==== Chunking/Embedding ====
EMBEDDING_MODEL=text-embedding-3-small  # 1536d
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5

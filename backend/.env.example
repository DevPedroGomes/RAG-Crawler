# ==== Required Settings ====

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key

# PostgreSQL Database with pgvector extension (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# Redis for job queue (required)
# Local: redis://localhost:6379/0
# With password: redis://:password@host:6379/0
# TLS (Railway/Cloud): rediss://username:password@host:port
REDIS_URL=redis://localhost:6379/0

# ==== Clerk Authentication ====

# JWKS URL for your Clerk instance (optional - defaults to Clerk API)
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=

# Comma-separated list of authorized frontend URLs (recommended for security)
# This validates the 'azp' (authorized party) claim in Clerk JWTs
# Example: http://localhost:3000,https://your-app.com
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# ==== RAG Settings ====

EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5

# ==== Crawler Settings ====

HEADLESS=true
BATCH_SIZE=12
CRAWL_DELAY_MS=0
USER_AGENT=RAGCrawler/1.0

# ==== Application Settings ====

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

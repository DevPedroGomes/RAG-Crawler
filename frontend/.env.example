# ==== Frontend / Next.js public ====

# Same-origin path; the Next.js rewrite at next.config.mjs forwards
# /api/backend/* to BACKEND_INTERNAL_URL.
NEXT_PUBLIC_API_URL=/api/backend

# Public-facing URL of the app (used by Better Auth as the trusted origin
# and as the OAuth redirect base).
NEXT_PUBLIC_APP_URL=https://ragcrawler.example.com

# ==== Server-only build args ====

# Where Next.js (running in the frontend container) reaches the FastAPI
# backend on the internal Docker network.
BACKEND_INTERNAL_URL=http://ragcrawler-backend:8000

# ==== Better Auth (server) ====

# 64-char random hex. Generate: `openssl rand -hex 32`
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32-output

# Public base URL Better Auth issues callback URLs against.
BETTER_AUTH_URL=https://ragcrawler.example.com

# Postgres URL for the shared DB (Better Auth tables live here too:
# user, session, account, verification — see backend/migrations/0001_better_auth.sql).
DATABASE_URL=postgresql://ragcrawler:CHANGE_ME@postgres:5432/ragdb

# Optional Google OAuth (sign-in button only renders when both are present).
# Create a Web client at https://console.cloud.google.com/apis/credentials with:
#   Authorized JS origin:    https://ragcrawler.example.com
#   Authorized redirect URI: https://ragcrawler.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
